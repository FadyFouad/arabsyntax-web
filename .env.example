# Public site origin used for canonical, hreflang, Open Graph, sitemap, and robots URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form email delivery.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SUPPORT_EMAIL=

# Contact form rate limiting. Optional locally; required for production hardening.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Use a stable value across production Worker deployments that may overlap.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# HMAC secret for signing quiz tokens (the stateless GET→submit grading handle).
# Optional locally (a dev fallback is used); set a stable random value in prod via
# `wrangler secret put QUIZ_TOKEN_SECRET`. Tokens never carry correct answers.
QUIZ_TOKEN_SECRET=

# ─── Web accounts (feature 006) ──────────────────────────────────────────────
# Launch-gate flag, baked in at build time. While unset, no account UI renders,
# no Firebase code is reachable, and the Firebase CSP allowances are omitted.
# Stays UNSET in production until launch gates G-1..G-4 pass (see
# specs/006-web-account-sync/launch-gates.md).
NEXT_PUBLIC_WEB_ACCOUNTS=

# Firebase web app config — Firebase console → Project settings → Your apps → Web.
# These are public by design (they identify the project, they don't authorize it);
# security lives in Firestore rules. Required only when NEXT_PUBLIC_WEB_ACCOUNTS=true.
NEXT_PUBLIC_FIREBASE_API_KEY=
# <project>.firebaseapp.com in dev. In production this becomes alnahwalkafi.com
# once the /__/auth same-origin proxy exists (needed by the redirect fallback in
# browsers that partition third-party storage).
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Present in the console's config snippet for completeness. Not used by this
# feature (auth + Firestore only): storageBucket is for Firebase Storage,
# messagingSenderId for FCM. Safe to fill in; leaving them blank changes nothing.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# Analytics (login / sign_up events). Requires a registered Web App in the project.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Point the SDK at the local Emulator Suite (`npm run emulators`) instead of the
# real project. Dev/e2e only — never set in a deployed build. Also relaxes the CSP
# to allow the emulator's http://127.0.0.1 origins.
NEXT_PUBLIC_FIREBASE_EMULATORS=
