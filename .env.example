# Public site origin used for canonical, hreflang, Open Graph, sitemap, and robots URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form email delivery.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SUPPORT_EMAIL=

# Contact form rate limiting. Optional locally; required for production hardening.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Use a stable value across production Worker deployments that may overlap.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# HMAC secret for signing quiz tokens (the stateless GET→submit grading handle).
# Optional locally (a dev fallback is used); set a stable random value in prod via
# `wrangler secret put QUIZ_TOKEN_SECRET`. Tokens never carry correct answers.
QUIZ_TOKEN_SECRET=
