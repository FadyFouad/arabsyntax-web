# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/blob-report
/.playwright

# next.js
/.next/
/out/
/.open-next/

# production
/build

# misc
.DS_Store
*.pem
content/lessons/.claude/
brain/
.wrangler/
cloudflare-env.d.ts

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.dev.vars*
!.env.example
!.dev.vars.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local planning notes
brain/

# generated at build time by scripts/generate-seo.mjs (served statically to
# bypass the OpenNext metadata-route handler)
/public/sitemap.xml
/public/robots.txt

# Firebase Emulator Suite runtime logs
firebase-debug.log
firestore-debug.log
ui-debug.log
*-debug.log
