# Security + caching headers for files served by the Cloudflare Workers Assets
# binding (favicon, sitemap.xml, robots.txt, /favicon/*, /og/*, /_next/static).
#
# next.config.ts `headers()` only decorates worker-rendered (HTML) responses, so
# static assets would otherwise ship with no security headers. CSP is omitted
# here on purpose: it governs document/script execution (set on HTML by the
# worker) and is not needed on standalone assets. More specific rules below
# override the catch-all for the same header name.

/*
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=63072000; includeSubDomains
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()

/_next/static/*
  Cache-Control: public,max-age=31536000,immutable
  X-Content-Type-Options: nosniff

# Icons, OG image, and the web manifest are stable but NOT content-hashed, so
# they can't be immutable (a rebrand must be able to propagate). A 7-day cache
# replaces the default `max-age=0, must-revalidate` — enough for browsers/CDNs
# (and a clean cacheability signal for crawlers) without locking in a stale
# favicon for a year. The /* security headers still apply (more-specific rules
# only override the same-named header).
/favicon.ico
  Cache-Control: public,max-age=604800
/favicon/*
  Cache-Control: public,max-age=604800
/og/*
  Cache-Control: public,max-age=604800
/manifest.webmanifest
  Cache-Control: public,max-age=604800
