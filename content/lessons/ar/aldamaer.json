        ],
        [
          "إيَّاهم",
          "للغائب الجمع المذكر"
        ],
        [
          "إيَّاهنَّ",
          "للغائب الجمع المؤنث"
        ]
      ]
    },
    {
      "id": "s020",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– إيَّاكَ نعبدُ وإيَّاكَ نستعينُ .",
          "underlined": [
            "إيَّاكَ",
            "إيَّاكَ"
          ]
        },
        {
          "text": "– إيَّاهم أكرمتُ .",
          "underlined": [
            "إيَّاهم"
          ]
        },
        {
          "text": "– إيَّاكَ والكذبَ .",
          "underlined": [
            "إيَّاكَ"
          ]
        }
      ]
    },
    {
      "id": "s021",
      "type": "highlight",
      "label": "ملاحظة",
      "text": "ضمائر النصب المنفصلة تُبنى دائمًا في محلِّ نصبٍ، وتقع غالبًا مفعولًا به مقدَّمًا على عامله."
    },
    {
      "id": "s022",
      "type": "heading",
      "text": "2- الضمائر المتصلة"
    },
    {
      "id": "s023",
      "type": "highlight",
      "label": "تعريف",
      "text": "الضمير المتصل: هو ما لا يُنطق به مستقلًّا، بل يتصل بكلمة قبله (فعل، أو اسم، أو حرف)، ولا يمكن الابتداء به."
    },
    {
      "id": "s024",
      "type": "paragraph",
      "text": "وتنقسم الضمائر المتصلة بحسب موقعها الإعرابي إلى ثلاثة أنواع: ضمائر رفع متصلة، وضمائر نصب وجرٍّ مشتركة، وضمير لا يكون إلا في محل جرٍّ."
    },
    {
      "id": "s025",
      "type": "heading",
      "text": "أ- ضمائر الرفع المتصلة"
    },
    {
      "id": "s026",
      "type": "highlight",
      "label": "قاعدة",
      "text": "ضمائر الرفع المتصلة هي: التاء المتحركة (تاء الفاعل)، ونا الفاعلين، وألف الاثنين، وواو الجماعة، وياء المخاطبة، ونون النسوة. وتتصل بالأفعال فقط، وتقع فاعلًا أو نائبَ فاعلٍ أو اسمًا لكان وأخواتها."
    },
    {
      "id": "s027",
      "type": "table",
      "headers": [
        "الضمير",
        "الدلالة",
        "المثال"
      ],
      "rows": [
        [
          "التاء المتحركة",
          "للمتكلم أو المخاطب",
          "كَتَبْتُ، كَتَبْتَ، كَتَبْتِ"
        ],
        [
          "نا الفاعلين",
          "للمتكلم المثنى أو الجمع",
          "كَتَبْنا"
        ],
        [
          "ألف الاثنين",
          "للمثنى الغائب أو المخاطب",
          "كَتَبَا، اكْتُبَا، يَكْتُبَانِ"
        ],
        [
          "واو الجماعة",
          "لجمع المذكر الغائب أو المخاطب",
          "كَتَبُوا، اكْتُبُوا، يَكْتُبُونَ"
        ],
        [
          "ياء المخاطبة",
          "للمخاطبة المؤنثة",
          "اكْتُبِي، تَكْتُبِينَ"
        ],
        [
          "نون النسوة",
          "لجمع الإناث الغائبات أو المخاطبات",
          "كَتَبْنَ، اكْتُبْنَ، يَكْتُبْنَ"
        ]
      ]
    },
    {
      "id": "s028",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– كَتَبْتُ الدرسَ .",
          "underlined": [
            "تُ"
          ]
        },
        {
          "text": "– كَتَبْنا الرسالةَ .",
          "underlined": [
            "نا"
          ]
        },
        {
          "text": "– الطالبانِ كَتَبَا الواجبَ .",
          "underlined": [
            "ا"
          ]
        },
        {
          "text": "– الطلابُ كَتَبُوا الدرسَ .",
          "underlined": [
            "وا"
          ]
        },
        {
          "text": "– يا فاطمةُ اكْتُبِي الدرسَ .",
          "underlined": [
            "ي"
          ]
        },
        {
          "text": "– الطالباتُ كَتَبْنَ الدرسَ .",
          "underlined": [
            "نَ"
          ]
        }
      ]
    },
    {
      "id": "s029",
      "type": "heading",
      "text": "ب- الضمائر المتصلة المشتركة (للنصب والجر)"
    },
    {
      "id": "s030",
      "type": "highlight",
      "label": "قاعدة",
      "text": "الضمائر المشتركة هي: ياء المتكلم، وكاف الخطاب، وهاء الغيبة، ونا الفاعلين. وتسمى مشتركة لأنها تكون في محل نصبٍ إذا اتصلت بفعل، وفي محل نصبٍ أو جرٍّ إذا اتصلت باسم، وفي محل جرٍّ إذا اتصلت بحرف جرٍّ."
    },
    {
      "id": "s031",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– أكرمَني المعلمُ . (في محل نصب مفعول به)",
          "underlined": [
            "ني"
          ]
        },
        {
          "text": "– كتابي جديدٌ . (في محل جر بالإضافة)",
          "underlined": [
            "ي"
          ]
        },
        {
          "text": "– إنَّني مجتهدٌ . (في محل نصب اسم إنَّ)",
          "underlined": [
            "ني"
          ]
        },
        {
          "text": "– سلَّمَ عليَّ المعلمُ . (في محل جر بحرف الجر)",
          "underlined": [
            "ي"
          ]
        }
      ]
    },
    {
      "id": "s032",
      "type": "table",
      "headers": [
        "الضمير",
        "اتصاله بالفعل",
        "اتصاله بالاسم",
        "اتصاله بالحرف"
      ],
      "rows": [
        [
          "ياء المتكلم",
          "أكرمَني (مفعول به)",
          "كتابي (مضاف إليه)",
          "عليَّ (مجرور)"
        ],
        [
          "كاف الخطاب",
          "أكرمَكَ (مفعول به)",
          "كتابُكَ (مضاف إليه)",
          "عليكَ (مجرور)"
        ],
        [
          "هاء الغيبة",
          "أكرمَهُ (مفعول به)",
          "كتابُهُ (مضاف إليه)",
          "عليهِ (مجرور)"
        ],
        [
          "نا الفاعلين",
          "أكرمَنا (مفعول به)",
          "كتابُنا (مضاف إليه)",
          "علينا (مجرور)"
        ]
      ]
    },
    {
      "id": "s033",
      "type": "highlight",
      "label": "تنبيه",
      "text": "ضمير (نا) يكون في محلِّ رفعٍ إذا كان فاعلًا، كما في (كَتَبْنا)، ويكون في محلِّ نصبٍ أو جرٍّ إذا اتصل باسم أو حرف جرٍّ، كما في (كتابُنا) و(علينا)."
    },
    {
      "id": "s034",
      "type": "heading",
      "text": "ج- الضمير الذي لا يكون إلا في محل جرٍّ"
    },
    {
      "id": "s035",
      "type": "highlight",
      "label": "قاعدة",
      "text": "ضمير المتكلم (ياء النسبة) يتصل بالاسم فيكون في محل جرٍّ بالإضافة، ولا يتصل بالفعل."
    },
    {
      "id": "s036",
      "type": "paragraph",
      "text": "ومن الضمائر التي لا تكون إلا في محل جرٍّ ما يتصل بحروف الجر مباشرة كقولنا: لي، لكَ، لهُ، منهُ، عنهم."
    },
    {
      "id": "s037",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– هذا كتابي .",
          "underlined": [
            "ي"
          ]
        },
        {
          "text": "– إنَّ لي صديقًا .",
          "underlined": [
            "ي"
          ]
        },
        {
          "text": "– سلَّمتُ عليه .",
          "underlined": [
            "ه"
          ]
        }
      ]
    },
    {
      "id": "s038",
      "type": "heading",
      "text": "ثانيًا: الضمائر المستترة"
    },
    {
      "id": "s039",
      "type": "highlight",
      "label": "تعريف",
      "text": "الضمير المستتر: هو ضميرٌ لا صورة له في اللفظ، بل يُقدَّر في الفعل ويعود على الفاعل."
    },
    {
      "id": "s040",
      "type": "paragraph",
      "text": "وينقسم الضمير المستتر إلى نوعين: مستتر وجوبًا، ومستتر جوازًا."
    },
    {
      "id": "s041",
      "type": "heading",
      "text": "1- الضمير المستتر وجوبًا"
    },
    {
      "id": "s042",
      "type": "highlight",
      "label": "قاعدة",
      "text": "الضمير المستتر وجوبًا هو الذي لا يصحُّ أن يحلَّ محلَّه اسمٌ ظاهرٌ ولا ضميرٌ منفصلٌ. ويكون في أربعة مواضع: مع الفعل المضارع المبدوء بهمزة المتكلم (أنا)، أو نون المتكلم (نحن)، أو تاء المخاطب المفرد (أنتَ)، ومع فعل الأمر للمخاطب المفرد."
    },
    {
      "id": "s043",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– أَكْتُبُ الدرسَ . (التقدير: أنا)",
          "underlined": [
            "أَكْتُبُ"
          ]
        },
        {
          "text": "– نَكْتُبُ الدرسَ . (التقدير: نحن)",
          "underlined": [
            "نَكْتُبُ"
          ]
        },
        {
          "text": "– تَكْتُبُ الدرسَ . (التقدير: أنتَ)",
          "underlined": [
            "تَكْتُبُ"
          ]
        },
        {
          "text": "– اكْتُبْ الدرسَ . (التقدير: أنتَ)",
          "underlined": [
            "اكْتُبْ"
          ]
        }
      ]
    },
    {
      "id": "s044",
      "type": "heading",
      "text": "2- الضمير المستتر جوازًا"
    },
    {
      "id": "s045",
      "type": "highlight",
      "label": "قاعدة",
      "text": "الضمير المستتر جوازًا هو الذي يصحُّ أن يحلَّ محلَّه اسمٌ ظاهرٌ. ويكون مع الفعل الماضي للغائب المفرد، والفعل المضارع المبدوء بياء الغيبة أو تاء الغيبة للمؤنث المفرد."
    },
    {
      "id": "s046",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– محمدٌ كَتَبَ الدرسَ . (التقدير: هو، ويصح: كَتَبَ محمدٌ)",
          "underlined": [
            "كَتَبَ"
          ]
        },
        {
          "text": "– الطالبُ يَكْتُبُ الدرسَ . (التقدير: هو)",
          "underlined": [
            "يَكْتُبُ"
          ]
        },
        {
          "text": "– فاطمةُ تَكْتُبُ الدرسَ . (التقدير: هي)",
          "underlined": [
            "تَكْتُبُ"
          ]
        }
      ]
    },
    {
      "id": "s047",
      "type": "heading",
      "text": "ضمير الشأن وضمير الفصل"
    },
    {
      "id": "s048",
      "type": "heading",
      "text": "1- ضمير الشأن"
    },
    {
      "id": "s049",
      "type": "highlight",
      "label": "تعريف",
      "text": "ضمير الشأن: ضمير غائب يتقدَّم على جملة تفسِّره، ويُسمَّى ضمير القصة إذا كان مؤنثًا، وضمير الشأن إذا كان مذكرًا. ويُستعمل لتفخيم الكلام وتعظيمه."
    },
    {
      "id": "s050",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– هو اللهُ أحدٌ .",
          "underlined": [
