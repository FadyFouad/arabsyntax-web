{
  "lesson_id": "nedaa",
  "language": "ar",
  "title": "تعريف المنادى",
  "sections": [
    {
      "id": "s001",
      "type": "heading",
      "text": "تعريف المنادى"
    },
    {
      "id": "s002",
      "type": "highlight",
      "label": "تعريف",
      "text": "المنادى وأسلوب النداء هو اسم يدل على طلب المتكلم من المخاطب الإقبال عليه، أو الانتباه إليه، يذكر بعد حرف من أحرف النداء وهي:"
    },
    {
      "id": "s003",
      "type": "heading",
      "text": "أدوات النداء"
    },
    {
      "id": "s004",
      "type": "heading",
      "text": "أي – أ"
    },
    {
      "id": "s005",
      "type": "paragraph",
      "text": "للمنادى القريب مثل: آمحمدُ – أي بني"
    },
    {
      "id": "s006",
      "type": "heading",
      "text": "آي – آ – أيا – هيا – واو الندبة"
    },
    {
      "id": "s007",
      "type": "paragraph",
      "text": "للمنادى البعيد مثل: أيا إبراهيمُ أقبلْ"
    },
    {
      "id": "s008",
      "type": "heading",
      "text": "يا"
    },
    {
      "id": "s009",
      "type": "paragraph",
      "text": "للمنادي سواء القريب أو البعيد"
    },
    {
      "id": "s010",
      "type": "paragraph",
      "text": "القريب مثل: اجلسْ يا رجلُ"
    },
    {
      "id": "s011",
      "type": "paragraph",
      "text": "والبعيد مثل: أقبلْ يا رجلُ"
    },
    {
      "id": "s012",
      "type": "heading",
      "text": "أحكام المنادى"
    },
    {
      "id": "s013",
      "type": "heading",
      "text": "العلم"
    },
    {
      "id": "s014",
      "type": "paragraph",
      "text": "يبنى على ما يرفع به في غير النداء، ويكون في محل نصب ، مثل قوله تعالى : ((قِيلَ يَا نُوحُ اهْبِطْ بِسَلَامٍ))"
    },
    {
      "id": "s015",
      "type": "heading",
      "text": "النكرة المقصودة"
    },
    {
      "id": "s016",
      "type": "paragraph",
      "text": "يبنى على ما يرفع به في غير النداء، ويكون في محل نصب ، مثل قوله تعالى : ((يَا جِبَالُ أَوِّبِي مَعَهُ))"
    },
    {
      "id": "s017",
      "type": "heading",
      "text": "النكرة غير المقصودة"
    },
    {
      "id": "s018",
      "type": "paragraph",
      "text": "حكمه واجب النصب مثل: يا عاصيًا تبْ إلى اللهِ"
    },
    {
      "id": "s019",
      "type": "heading",
      "text": "المضاف"
    },
    {
      "id": "s020",
      "type": "paragraph",
      "text": "حكمه واجب النصب"
    },
    {
      "id": "s021",
      "type": "paragraph",
      "text": "مثل قوله تعالى : ((يَا أَهْلَ الْكِتَابِ لِمَ تُحَاجُّونَ فِي إِبْرَاهِيمَ))"
    },
    {
      "id": "s022",
      "type": "heading",
      "text": "الشبيه بالمضاف"
    },
    {
      "id": "s023",
      "type": "paragraph",
      "text": "وهو ما لا يمكننا الاستغناء عما لحق بالمنادى مثل: يا طالعًا جبلًا ، وحكمه واجب النصب"
    },
    {
      "id": "s024",
      "type": "heading",
      "text": "المنادى المضاف إلى ياء المتكلم"
    },
    {
      "id": "s025",
      "type": "heading",
      "text": "صحيح الآخر"
    },
    {
      "id": "s026",
      "type": "heading",
      "text": "إثبات الياء"
    },
    {
      "id": "s027",
      "type": "paragraph",
      "text": "مبنية على:"
    },
    {
      "id": "s028",
      "type": "paragraph",
      "text": "السكون (يا صديقيْ)\nأو الفتح (يا صديقيَ)"
    },
    {
      "id": "s029",
      "type": "paragraph",
      "text": "أو حذفها والاكتفاء بكسر ما قبلها"
    },
    {
      "id": "s030",
      "type": "paragraph",
      "text": "مثل قوله تعالى : ((يَا عِبَادِ فَاتَّقُونِ))"
    },
    {
      "id": "s031",
      "type": "paragraph",
      "text": "أو فتحه وقلب الياء ألفا"
    },
    {
      "id": "s032",
      "type": "paragraph",
      "text": "مثل قوله تعالى : ((يَا حَسْرَتَا عَلَى مَا فَرَّطْتُ فِي جَنْبِ اللَّهِ))"
    },
    {
      "id": "s033",
      "type": "heading",
      "text": "معتل الآخر"
    },
    {
      "id": "s034",
      "type": "paragraph",
      "text": "يجب إثباتها وتكون مبنية على الفتح مثل: يا محاميَّ"
    },
    {
      "id": "s035",
      "type": "heading",
      "text": "اسم فاعل أو أحد مبالغاته أو اسم المفعول"
    },
    {
      "id": "s036",
      "type": "paragraph",
      "text": "يجب إثباتها"
    },
    {
      "id": "s037",
      "type": "paragraph",
      "text": "وتكون مبنية على الفتح مثل: يا معلميَ"
    },
    {
      "id": "s038",
      "type": "paragraph",
      "text": "أو السكون"
    },
    {
      "id": "s039",
      "type": "example",
      "style": "sentences",
      "items": [
        "– يا مجروحي"
      ]
    },
    {
      "id": "s040",
      "type": "heading",
      "text": "أب – أم"
    },
    {
      "id": "s041",
      "type": "paragraph",
      "text": "لهما نفس أحكام الصحيح الآخر، ويمكن حذف الياء والتعويض عنها بتاء التأنيث المفتوحة"
    },
    {
      "id": "s042",
      "type": "example",
      "style": "sentences",
      "items": [
        "– يا أبتَ ، ويا أمَّ"
      ]
    },
    {
      "id": "s043",
      "type": "paragraph",
      "text": "أو المكسورة"
    },
    {
      "id": "s044",
      "type": "example",
      "style": "sentences",
      "items": [
        "– يا أبتِ ويا أمِّ"
      ]
    },
    {
      "id": "s045",
      "type": "heading",
      "text": "حذف أداة النداء:"
    },
    {
      "id": "s046",
      "type": "paragraph",
      "text": "يمكن حذف أداة النداء وتقدر بـ يا لأنها أم الباب ولكن يمنع حذفها في مواضع هي:"
    },
    {
      "id": "s047",
      "type": "paragraph",
      "text": "1- المندوب:"
    },
    {
      "id": "s048",
      "type": "example",
      "style": "sentences",
      "items": [
        "– يا حسرتا"
      ]
    },
    {
      "id": "s049",
      "type": "paragraph",
      "text": "2- المستغاث:"
    },
    {
      "id": "s050",
      "type": "example",
      "style": "sentences",
      "items": [
        "– يالمحمد"
      ]
    },
    {
      "id": "s051",
      "type": "paragraph",
      "text": "3- النكرة غير المقصودة:"
    },
    {
      "id": "s052",
      "type": "example",
      "style": "sentences",
      "items": [
        "– يا سامعًا أقبل"
      ]
    },
    {
      "id": "s053",
      "type": "paragraph",
      "text": "4- النكرة المقصودة:"
    },
    {
      "id": "s054",
      "type": "example",
      "style": "sentences",
      "items": [
        "– يا شرطيُ أغثني"
      ]
    },
    {
      "id": "s055",
      "type": "paragraph",
      "text": "5- اسم الإشارة:"
    },
    {
      "id": "s056",
      "type": "example",
      "style": "sentences",
      "items": [
        "– قف يا هذا"
      ]
    },
    {
      "id": "s057",
      "type": "paragraph",
      "text": "6- المنادى البعيد:"
    },
    {
      "id": "s058",
      "type": "example",
      "style": "sentences",
      "items": [
        "– يا سائقَ السيارةِ"
      ]
    },
    {
      "id": "s059",
      "type": "paragraph",
      "text": "7- الضمير المخاطب:"
    },
    {
      "id": "s060",
      "type": "example",
      "style": "sentences",
      "items": [
        "– يا أنتَ استمع لقولي"
      ]
    },
    {
      "id": "s061",
      "type": "paragraph",
      "text": "8- لفظ الجلالة:"
    },
    {
      "id": "s062",
      "type": "example",
      "style": "sentences",
      "items": [
        "– يا اللهُ استجبْ"
      ]
    }
  ]
}
