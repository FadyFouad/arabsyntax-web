    {
      "id": "s020",
      "type": "heading",
      "text": "ثانيًا: المصدر المؤول"
    },
    {
      "id": "s021",
      "type": "highlight",
      "label": "تعريف",
      "text": "المصدر المؤول هو ما تركَّب من حرفٍ مصدريٍّ مع ما بعده، ويُؤوَّل بمصدر صريحٍ يحلُّ محلَّه."
    },
    {
      "id": "s022",
      "type": "heading",
      "text": "الحروف المصدرية"
    },
    {
      "id": "s023",
      "type": "highlight",
      "label": "قاعدة",
      "text": "الحروف المصدرية التي يُتكوَّن منها المصدر المؤول هي: أنْ، أنَّ، كي، ما، لو، همزة التسوية. وكلُّ حرفٍ منها يُؤوَّل مع ما بعده بمصدر صريحٍ."
    },
    {
      "id": "s024",
      "type": "heading",
      "text": "1- (أنْ) المصدرية مع الفعل"
    },
    {
      "id": "s025",
      "type": "highlight",
      "label": "قاعدة",
      "text": "إذا دخلت (أنْ) المصدرية على فعلٍ مضارعٍ أو ماضٍ، أُوِّلت معه بمصدر صريحٍ."
    },
    {
      "id": "s026",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– يَسُرُّني أنْ تَنْجَحَ . (التأويل: نجاحُكَ)",
          "underlined": [
            "أنْ تَنْجَحَ"
          ]
        },
        {
          "text": "– يُعْجِبُني أنْ تَجْتَهِدَ . (التأويل: اجتهادُكَ)",
          "underlined": [
            "أنْ تَجْتَهِدَ"
          ]
        },
        {
          "text": "– سَعِدْتُ بأنْ زُرْتَني . (التأويل: بزيارتِكَ)",
          "underlined": [
            "أنْ زُرْتَني"
          ]
        }
      ]
    },
    {
      "id": "s027",
      "type": "heading",
      "text": "2- (أنَّ) المصدرية مع اسمها وخبرها"
    },
    {
      "id": "s028",
      "type": "highlight",
      "label": "قاعدة",
      "text": "إذا جاءت (أنَّ) ومعها اسمها وخبرها، أُوِّلت معهما بمصدر صريحٍ، ويُسبك المصدر من خبرها مضافًا إلى اسمها."
    },
    {
      "id": "s029",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– سَرَّني أنَّكَ ناجحٌ . (التأويل: نجاحُكَ)",
          "underlined": [
            "أنَّكَ ناجحٌ"
          ]
        },
        {
          "text": "– بَلَغَني أنَّ المعلمَ مسافرٌ . (التأويل: سفرُ المعلمِ)",
          "underlined": [
            "أنَّ المعلمَ مسافرٌ"
          ]
        },
        {
          "text": "– يُعْجِبُني أنَّ الطالبَ مجتهدٌ . (التأويل: اجتهادُ الطالبِ)",
          "underlined": [
            "أنَّ الطالبَ مجتهدٌ"
          ]
        }
      ]
    },
    {
      "id": "s030",
      "type": "heading",
      "text": "3- (كي) المصدرية مع الفعل"
    },
    {
      "id": "s031",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– جئتُ كي أتعلَّمَ . (التأويل: للتعلُّمِ)",
          "underlined": [
            "كي أتعلَّمَ"
          ]
        },
        {
          "text": "– اجتهدْ كي تَنْجَحَ . (التأويل: للنجاحِ)",
          "underlined": [
            "كي تَنْجَحَ"
          ]
        }
      ]
    },
    {
      "id": "s032",
      "type": "heading",
      "text": "4- (ما) المصدرية مع الفعل"
    },
    {
      "id": "s033",
      "type": "highlight",
      "label": "قاعدة",
      "text": "(ما) المصدرية تُؤوَّل مع ما بعدها بمصدرٍ صريحٍ، وتُسمَّى أحيانًا (ما) المصدرية الظرفية إذا دلَّت على زمن."
    },
    {
      "id": "s034",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– يُعْجِبُني ما تَفْعَلُ . (التأويل: فِعْلُكَ)",
          "underlined": [
            "ما تَفْعَلُ"
          ]
        },
        {
          "text": "– سأظلُّ صديقَكَ ما حييتُ . (التأويل: مدةَ حياتي)",
          "underlined": [
            "ما حييتُ"
          ]
        }
      ]
    },
    {
      "id": "s035",
      "type": "heading",
      "text": "5- (لو) المصدرية مع الفعل"
    },
    {
      "id": "s036",
      "type": "highlight",
      "label": "قاعدة",
      "text": "(لو) المصدرية تأتي بمعنى (أنْ)، وتُؤوَّل مع ما بعدها بمصدرٍ صريحٍ، وتقع غالبًا بعد فعل التمنِّي أو الودِّ."
    },
    {
      "id": "s037",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– يَوَدُّ الكسولُ لو يَنْجَحُ . (التأويل: نجاحَهُ)",
          "underlined": [
            "لو يَنْجَحُ"
          ]
        },
        {
          "text": "– وَدِدْتُ لو زرتُكَ . (التأويل: زيارتَكَ)",
          "underlined": [
            "لو زرتُكَ"
          ]
        }
      ]
    },
    {
      "id": "s038",
      "type": "heading",
      "text": "6- همزة التسوية"
    },
    {
      "id": "s039",
      "type": "highlight",
      "label": "تعريف",
      "text": "همزة التسوية: همزة استفهام تأتي بعد لفظ يدلُّ على الاستواء كـ (سواء)، وتُؤوَّل مع ما بعدها بمصدرٍ صريحٍ."
    },
    {
      "id": "s040",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– سواءٌ عليَّ أَحضرتَ أمْ غبتَ . (التأويل: حضورُكَ وغيابُكَ)",
          "underlined": [
            "أَحضرتَ أمْ غبتَ"
          ]
        },
        {
          "text": "– سواءٌ عليهم أَأنذرتَهم أمْ لم تُنذرْهم . (التأويل: إنذارُكَ وعدمُهُ)",
          "underlined": [
            "أَأنذرتَهم أمْ لم تُنذرْهم"
          ]
        }
      ]
    },
    {
      "id": "s041",
      "type": "heading",
      "text": "كيفية تأويل المصدر المؤول إلى صريح"
    },
    {
      "id": "s042",
      "type": "highlight",
      "label": "قاعدة",
      "text": "لتأويل المصدر المؤول إلى مصدر صريح، تُؤخذ مادة الفعل ويُصاغ منها المصدر، ثم يُضاف إلى الفاعل أو الاسم. وفي حالة (أنَّ) واسمها وخبرها: يُصاغ المصدر من الخبر ويُضاف إلى الاسم."
    },
