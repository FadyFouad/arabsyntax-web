        ]
      ]
    },
    {
      "id": "s043",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– إنْ تَجْتَهِدْ تَنْجَحْ .",
          "underlined": [
            "تَجْتَهِدْ",
            "تَنْجَحْ"
          ]
        },
        {
          "text": "– مَنْ يَزْرَعْ يَحْصُدْ .",
          "underlined": [
            "يَزْرَعْ",
            "يَحْصُدْ"
          ]
        },
        {
          "text": "– ما تَفْعَلْ مِنْ خيرٍ تَجِدْهُ .",
          "underlined": [
            "تَفْعَلْ",
            "تَجِدْهُ"
          ]
        },
        {
          "text": "– مهما تُخْفِ يَعْلَمْهُ اللهُ .",
          "underlined": [
            "تُخْفِ",
            "يَعْلَمْهُ"
          ]
        },
        {
          "text": "– متى تَأْتِنا تَجِدْنا .",
          "underlined": [
            "تَأْتِنا",
            "تَجِدْنا"
          ]
        },
        {
          "text": "– أينما تَذْهَبْ أَذْهَبْ معكَ .",
          "underlined": [
            "تَذْهَبْ",
            "أَذْهَبْ"
          ]
        },
        {
          "text": "– كيفما تَكُنْ يَكُنْ قَرينُكَ .",
          "underlined": [
            "تَكُنْ",
            "يَكُنْ"
          ]
        },
        {
          "text": "– أيَّ كتابٍ تَقْرَأْ تَسْتَفِدْ منه .",
          "underlined": [
            "تَقْرَأْ",
            "تَسْتَفِدْ"
          ]
        }
      ]
    },
    {
      "id": "s044",
      "type": "heading",
      "text": "علامات جزم الفعل المضارع"
    },
    {
      "id": "s045",
      "type": "list",
      "items": [
        "السكون: إذا كان صحيح الآخر، مثل: لمْ يَكْتُبْ.",
