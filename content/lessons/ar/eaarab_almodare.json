{
  "lesson_id": "eaarab_almodare",
  "language": "ar",
  "title": "إعراب الفعل المضارع",
  "sections": [
    {
      "id": "s001",
      "type": "heading",
      "text": "إعراب الفعل المضارع"
    },
    {
      "id": "s002",
      "type": "paragraph",
      "text": "الفعل المضارع هو الفعل الوحيد المعرب من بين الأفعال، فهو يقبل التغيير في آخره بحسب العوامل التي تدخل عليه. وله ثلاث حالات إعرابية: الرفع، والنصب، والجزم."
    },
    {
      "id": "s003",
      "type": "highlight",
      "label": "قاعدة",
      "text": "الفعل المضارع يكون مرفوعًا إذا لم يسبقه ناصبٌ ولا جازمٌ، ويكون منصوبًا إذا سبقه أحد أدوات النصب، ويكون مجزومًا إذا سبقه أحد أدوات الجزم."
    },
    {
      "id": "s004",
      "type": "heading",
      "text": "أولًا: رفع الفعل المضارع"
    },
    {
      "id": "s005",
      "type": "highlight",
      "label": "قاعدة",
      "text": "يُرفع الفعل المضارع إذا تجرد من الناصب والجازم، أي لم يسبقه أحد أدوات النصب أو الجزم."
    },
    {
      "id": "s006",
      "type": "heading",
      "text": "علامات رفع الفعل المضارع"
    },
    {
      "id": "s007",
      "type": "list",
      "items": [
        "الضمة الظاهرة: إذا كان صحيح الآخر، مثل: يَكْتُبُ، يَدْرُسُ.",
        "الضمة المقدرة: إذا كان معتل الآخر بالألف أو الواو أو الياء، مثل: يَسْعَى، يَدْعُو، يَقْضِي.",
        "ثبوت النون: إذا كان من الأفعال الخمسة (المضارع المتصل بألف الاثنين، أو واو الجماعة، أو ياء المخاطبة)، مثل: يَكْتُبَانِ، يَكْتُبُونَ، تَكْتُبِينَ."
      ]
    },
    {
      "id": "s008",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– يَجْتَهِدُ الطالبُ في دروسِهِ .",
          "underlined": [
            "يَجْتَهِدُ"
          ]
        },
        {
          "text": "– يَسْعَى المؤمنُ إلى الخيرِ .",
          "underlined": [
            "يَسْعَى"
          ]
        },
        {
          "text": "– يَدْعُو الواعظُ إلى اللهِ .",
          "underlined": [
            "يَدْعُو"
          ]
        },
        {
          "text": "– يَقْضِي القاضي بالحقِّ .",
          "underlined": [
            "يَقْضِي"
          ]
        },
        {
          "text": "– الطالبانِ يَكْتُبَانِ الدرسَ .",
          "underlined": [
            "يَكْتُبَانِ"
          ]
        },
        {
          "text": "– الطلابُ يَكْتُبُونَ الدرسَ .",
          "underlined": [
            "يَكْتُبُونَ"
          ]
        },
        {
          "text": "– أنتِ تَكْتُبِينَ الدرسَ .",
          "underlined": [
            "تَكْتُبِينَ"
          ]
        }
      ]
    },
    {
      "id": "s009",
      "type": "highlight",
      "label": "تعريف",
      "text": "الأفعال الخمسة هي كل فعل مضارع اتصلت به ألف الاثنين، أو واو الجماعة، أو ياء المخاطبة، وأوزانها: يَفْعَلَانِ، تَفْعَلَانِ، يَفْعَلُونَ، تَفْعَلُونَ، تَفْعَلِينَ."
    },
    {
      "id": "s010",
      "type": "heading",
      "text": "ثانيًا: نصب الفعل المضارع"
    },
    {
      "id": "s011",
      "type": "highlight",
      "label": "قاعدة",
      "text": "يُنصب الفعل المضارع إذا سبقه أحد أدوات النصب، وهي: أَنْ، لَنْ، كَيْ، لامُ التعليلِ، حتى، فاءُ السببيةِ، واوُ المعيةِ، لامُ الجحودِ، إذنْ."
    },
    {
      "id": "s012",
      "type": "heading",
      "text": "أدوات نصب الفعل المضارع"
    },
    {
      "id": "s013",
      "type": "highlight",
      "label": "تعريف",
      "text": "أَنْ: حرف مصدري ونصب واستقبال، يُؤوَّل مع الفعل بعده بمصدر."
    },
    {
      "id": "s014",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– يَسُرُّني أنْ تَنْجَحَ .",
          "underlined": [
            "تَنْجَحَ"
          ]
        },
        {
          "text": "– أُحِبُّ أنْ أَقْرَأَ القرآنَ .",
          "underlined": [
            "أَقْرَأَ"
          ]
        }
      ]
    },
    {
      "id": "s015",
      "type": "highlight",
      "label": "تعريف",
      "text": "لَنْ: حرف نصب ونفي واستقبال، يدلُّ على نفي الفعل في المستقبل."
    },
    {
      "id": "s016",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– لنْ أَتَأَخَّرَ عن الحضورِ .",
          "underlined": [
            "أَتَأَخَّرَ"
          ]
        },
        {
          "text": "– لنْ يَفُوزَ الكسولُ .",
          "underlined": [
            "يَفُوزَ"
          ]
        }
      ]
    },
    {
      "id": "s017",
      "type": "highlight",
      "label": "تعريف",
      "text": "كَيْ: حرف مصدري ونصب يفيد التعليل."
    },
    {
      "id": "s018",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– اجتهدْ كي تَنْجَحَ .",
          "underlined": [
            "تَنْجَحَ"
          ]
        },
        {
          "text": "– ادرسْ كي تَتَفَوَّقَ .",
          "underlined": [
            "تَتَفَوَّقَ"
          ]
        }
      ]
    },
    {
      "id": "s019",
      "type": "highlight",
      "label": "تعريف",
      "text": "لامُ التعليلِ: لام مكسورة تدخل على الفعل المضارع لتفيد التعليل، وتنصبه بـ (أنْ) مضمرة وجوبًا."
    },
    {
      "id": "s020",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– جئتُ لِأَتَعَلَّمَ .",
          "underlined": [
            "أَتَعَلَّمَ"
          ]
        },
        {
          "text": "– ذهبتُ إلى المسجدِ لِأُصَلِّيَ .",
          "underlined": [
            "أُصَلِّيَ"
          ]
        }
      ]
    },
    {
      "id": "s021",
      "type": "highlight",
      "label": "تعريف",
      "text": "حتى: حرف جر ونصب يفيد الغاية أو التعليل، وينصب الفعل المضارع بـ (أنْ) مضمرة وجوبًا."
    },
    {
      "id": "s022",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– اجتهدْ حتى تَنْجَحَ .",
          "underlined": [
            "تَنْجَحَ"
          ]
        },
        {
          "text": "– سرتُ حتى أَبْلُغَ المدينةَ .",
          "underlined": [
            "أَبْلُغَ"
          ]
        }
      ]
    },
    {
      "id": "s023",
      "type": "highlight",
      "label": "تعريف",
      "text": "فاءُ السببيةِ: فاء تدلُّ على أن ما قبلها سببٌ لما بعدها، وتُسبَق بنفي أو طلب (أمر، نهي، استفهام، تمنٍّ، ترجٍّ، عرض، تحضيض)."
    },
    {
      "id": "s024",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– اجتهدْ فَتَنْجَحَ .",
          "underlined": [
            "فَتَنْجَحَ"
          ]
        },
        {
          "text": "– لا تَكْسَلْ فَتَنْدَمَ .",
          "underlined": [
            "فَتَنْدَمَ"
          ]
        },
        {
          "text": "– هل تَزُورُنا فَنُكْرِمَكَ ؟",
          "underlined": [
            "فَنُكْرِمَكَ"
          ]
        }
      ]
    },
    {
      "id": "s025",
      "type": "highlight",
      "label": "تعريف",
      "text": "واوُ المعيةِ: واو تدلُّ على المصاحبة، وتُسبَق بنفي أو طلب كفاء السببية."
    },
    {
      "id": "s026",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– لا تَنْهَ عن خُلُقٍ وَتَأْتِيَ مثلَهُ .",
          "underlined": [
            "وَتَأْتِيَ"
          ]
        },
        {
          "text": "– لا تأكلْ السمكَ وَتَشْرَبَ اللبنَ .",
          "underlined": [
            "وَتَشْرَبَ"
          ]
        }
      ]
    },
    {
      "id": "s027",
      "type": "highlight",
      "label": "تعريف",
      "text": "لامُ الجحودِ: لام مكسورة تُسبَق بكون منفي (ما كان، لم يكن)، وتنصب الفعل المضارع بـ (أنْ) مضمرة وجوبًا."
    },
    {
      "id": "s028",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– ما كان اللهُ لِيُعَذِّبَهُمْ .",
          "underlined": [
            "لِيُعَذِّبَهُمْ"
          ]
        },
        {
          "text": "– لم يكنْ المؤمنُ لِيَكْذِبَ .",
          "underlined": [
            "لِيَكْذِبَ"
          ]
        }
      ]
    },
    {
      "id": "s029",
      "type": "highlight",
      "label": "تعريف",
      "text": "إذنْ: حرف جواب وجزاء ونصب، تدلُّ على جواب وجزاء لكلام سابق، وتنصب الفعل المضارع بشروط: أن تكون في صدر الكلام، وأن يكون الفعل بعدها للمستقبل، وألا يفصل بينها وبين الفعل فاصل غير القسم."
    },
    {
      "id": "s030",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– (سأزورك غدًا) إذنْ أُكْرِمَكَ .",
          "underlined": [
            "أُكْرِمَكَ"
          ]
        },
        {
          "text": "– (سأجتهد) إذنْ تَنْجَحَ .",
          "underlined": [
            "تَنْجَحَ"
          ]
        }
      ]
    },
    {
      "id": "s031",
      "type": "heading",
      "text": "علامات نصب الفعل المضارع"
    },
    {
      "id": "s032",
      "type": "list",
      "items": [
        "الفتحة الظاهرة: إذا كان صحيح الآخر أو معتله بالواو أو الياء، مثل: لنْ يَكْتُبَ، لنْ يَدْعُوَ، لنْ يَقْضِيَ.",
        "الفتحة المقدرة: إذا كان معتل الآخر بالألف، مثل: لنْ يَسْعَى.",
        "حذف النون: إذا كان من الأفعال الخمسة، مثل: لنْ يَكْتُبَا، لنْ يَكْتُبُوا، لنْ تَكْتُبِي."
      ]
    },
    {
      "id": "s033",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– لنْ يُهْمِلَ الطالبُ واجبَهُ .",
          "underlined": [
            "يُهْمِلَ"
          ]
        },
        {
          "text": "– لنْ يَسْعَى الكسولُ إلى المجدِ .",
          "underlined": [
            "يَسْعَى"
          ]
        },
        {
          "text": "– لنْ يَدْعُوَ المؤمنُ إلا اللهَ .",
          "underlined": [
            "يَدْعُوَ"
          ]
        },
        {
          "text": "– لنْ يَقْضِيَ الظالمُ بالعدلِ .",
          "underlined": [
            "يَقْضِيَ"
          ]
        },
        {
          "text": "– الطالبانِ لنْ يَتَأَخَّرَا .",
          "underlined": [
            "يَتَأَخَّرَا"
          ]
        },
        {
          "text": "– الطلابُ لنْ يَتَأَخَّرُوا .",
          "underlined": [
            "يَتَأَخَّرُوا"
          ]
        },
        {
          "text": "– أنتِ لنْ تَتَأَخَّرِي .",
          "underlined": [
            "تَتَأَخَّرِي"
          ]
        }
      ]
    },
    {
      "id": "s034",
      "type": "heading",
      "text": "ثالثًا: جزم الفعل المضارع"
    },
    {
      "id": "s035",
      "type": "highlight",
      "label": "قاعدة",
      "text": "يُجزم الفعل المضارع إذا سبقه أحد أدوات الجزم، وأدوات الجزم نوعان: ما يجزم فعلًا واحدًا، وما يجزم فعلين."
    },
    {
      "id": "s036",
      "type": "heading",
      "text": "أولًا: الأدوات التي تجزم فعلًا واحدًا"
    },
    {
      "id": "s037",
      "type": "list",
      "items": [
        "لَمْ: حرف نفي وجزم وقلب، تنفي الفعل في الماضي.",
        "لَمَّا: حرف نفي وجزم وقلب، تنفي الفعل في الماضي مع استمرار النفي إلى زمن التكلم.",
        "لامُ الأمرِ: لام مكسورة تدلُّ على الطلب.",
        "لا الناهيةُ: حرف نهي وجزم، تدلُّ على طلب الكفِّ عن الفعل."
      ]
    },
    {
      "id": "s038",
      "type": "example",
      "style": "sentences",
      "items": [
        {
          "text": "– لمْ يَحْضُرْ الطالبُ .",
          "underlined": [
            "يَحْضُرْ"
          ]
        },
        {
          "text": "– لمَّا يَأْتِ المعلمُ .",
          "underlined": [
            "يَأْتِ"
          ]
        },
        {
          "text": "– لِيَجْتَهِدْ كلُّ طالبٍ .",
          "underlined": [
            "لِيَجْتَهِدْ"
          ]
        },
        {
          "text": "– لا تُهْمِلْ واجبَكَ .",
          "underlined": [
            "تُهْمِلْ"
          ]
        }
      ]
    },
    {
      "id": "s039",
      "type": "highlight",
      "label": "ملاحظة",
      "text": "الفرق بين (لم) و(لمَّا): أن (لم) تنفي الفعل في الماضي، وقد ينقطع نفيها أو يستمر، أما (لمَّا) فتنفي الفعل في الماضي مع استمرار النفي إلى زمن التكلم وتوقع حدوثه."
    },
    {
      "id": "s040",
      "type": "heading",
      "text": "ثانيًا: الأدوات التي تجزم فعلين"
    },
    {
      "id": "s041",
      "type": "highlight",
      "label": "قاعدة",
      "text": "هي أدوات الشرط الجازمة، تجزم فعلين: الأول فعل الشرط، والثاني جواب الشرط. وهي: إنْ، مَنْ، ما، مهما، متى، أيَّان، أين، أنَّى، حيثما، كيفما، أيٌّ."
    },
    {
